# ChainPilot Data Engineering — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env to source control.

# PostgreSQL connection string for the target (test) database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://chainpilot:password@localhost:5432/chainpilot_test

# Optional: override paths (defaults shown)
# RAW_DATA_DIR=Raw_data
# LOGS_DIR=logs
# STAGING_DIR=staging
