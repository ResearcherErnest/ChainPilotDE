# ChainPilot Data Engineering — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env to source control.
#
# This is the ONE file to edit for any environment setting.
# All scripts read from config.py which loads these values automatically.

# ── Database credentials ──────────────────────────────────────────────
DB_USER=chainpilot
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chainpilot_test

# ── Optional: override directory paths (defaults shown) ───────────────
# RAW_DATA_DIR=Raw_data
# LOGS_DIR=logs
